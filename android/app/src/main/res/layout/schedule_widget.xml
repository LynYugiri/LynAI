<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/schedule_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/schedule_widget_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/schedule_widget_date_bg"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/schedule_widget_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="13"
                android:textColor="#FFFFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/schedule_widget_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="2026.5"
                android:textColor="#D7E6FFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/schedule_widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026 年 5 月"
                android:textColor="#FF0F172A"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/schedule_widget_weekday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="星期三"
                android:textColor="#FF64748B"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/schedule_widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/schedule_widget_pill_bg"
            android:paddingStart="9dp"
            android:paddingTop="5dp"
            android:paddingEnd="9dp"
            android:paddingBottom="5dp"
            android:text="下一项 09:00"
            android:textColor="#FF1D4ED8"
            android:textSize="11sp" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/schedule_widget_calendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:alignmentMode="alignBounds"
        android:columnCount="7"
        android:rowCount="7"
        android:useDefaultMargins="false">

        <TextView style="@style/ScheduleWidgetWeekday" android:text="一" />
        <TextView style="@style/ScheduleWidgetWeekday" android:text="二" />
        <TextView style="@style/ScheduleWidgetWeekday" android:text="三" />
        <TextView style="@style/ScheduleWidgetWeekday" android:text="四" />
        <TextView style="@style/ScheduleWidgetWeekday" android:text="五" />
        <TextView style="@style/ScheduleWidgetWeekday" android:text="六" />
        <TextView style="@style/ScheduleWidgetWeekday" android:text="日" />

        <TextView android:id="@+id/schedule_widget_day_1" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_2" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_3" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_4" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_5" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_6" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_7" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_8" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_9" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_10" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_11" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_12" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_13" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_14" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_15" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_16" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_17" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_18" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_19" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_20" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_21" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_22" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_23" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_24" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_25" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_26" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_27" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_28" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_29" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_30" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_31" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_32" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_33" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_34" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_35" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_36" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_37" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_38" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_39" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_40" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_41" style="@style/ScheduleWidgetDay" />
        <TextView android:id="@+id/schedule_widget_day_42" style="@style/ScheduleWidgetDay" />
    </GridLayout>

    <LinearLayout
        android:id="@+id/schedule_widget_agenda"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/schedule_widget_agenda_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="今日日程"
            android:textColor="#FF334155"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView android:id="@+id/schedule_widget_agenda_1" style="@style/ScheduleWidgetAgenda" />
        <TextView android:id="@+id/schedule_widget_agenda_2" style="@style/ScheduleWidgetAgenda" />
        <TextView android:id="@+id/schedule_widget_agenda_3" style="@style/ScheduleWidgetAgenda" />
    </LinearLayout>
</LinearLayout>
